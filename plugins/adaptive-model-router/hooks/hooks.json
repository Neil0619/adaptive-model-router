{
  "description": "Apply explicit router controls and enforce outcome recording for delegated stages.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/node-launcher.mjs\" \"$PLUGIN_ROOT/scripts/hook.mjs\" prompt",
            "commandWindows": "node -e \"const path=require('node:path');const {pathToFileURL}=require('node:url');const root=process.env.PLUGIN_ROOT;const launcher=path.join(root,'scripts','node-launcher.mjs');process.argv=[process.execPath,launcher,path.join(root,'scripts','hook.mjs'),'prompt'];import(pathToFileURL(launcher).href)\"",
            "timeout": 15,
            "statusMessage": "Checking Adaptive Model Router controls"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/node-launcher.mjs\" \"$PLUGIN_ROOT/scripts/hook.mjs\" stop",
            "commandWindows": "node -e \"const path=require('node:path');const {pathToFileURL}=require('node:url');const root=process.env.PLUGIN_ROOT;const launcher=path.join(root,'scripts','node-launcher.mjs');process.argv=[process.execPath,launcher,path.join(root,'scripts','hook.mjs'),'stop'];import(pathToFileURL(launcher).href)\"",
            "timeout": 15,
            "statusMessage": "Checking routed-stage verification"
          }
        ]
      }
    ]
  }
}
